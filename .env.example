# Root-level env passed into docker compose. The backend reads its own
# backend/server/.env; this file is consumed by `docker compose` only.
#
# Copy to `.env` and fill in values. Do NOT commit `.env` to git.

# Shared secret used by ai-services to call the backend (and vice versa).
# Must match backend's INTERNAL_API_KEY in backend/server/.env.
INTERNAL_API_KEY=dev-internal-api-key

# Groq API key for the AI services (decision + caption). Get one at
# https://console.groq.com — the ai-services container won't start without
# a valid key (decision + caption will return 500).
GROQ_API_KEY=
