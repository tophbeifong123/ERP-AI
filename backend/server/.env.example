# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=erp
DATABASE_PASSWORD=erp
DATABASE_NAME=erp_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
# Host embedded in presigned URLs handed to external callers (n8n container).
# In docker-compose, MinIO is reachable as `minio:9000` from other containers.
S3_PRESIGN_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=erp-ai
S3_PUBLIC_URL=http://localhost:9000/erp-ai

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-access-secret
JWT_REFRESH_SECRET=change-me-in-prod-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Internal (AI services)
INTERNAL_API_KEY=change-me-in-prod

# Facebook
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:3000/facebook/oauth/callback
FB_TOKEN_ENCRYPTION_KEY=

# Email (Mailhog dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ERP-AI <noreply@example.com>

# AI Services
# Decision + Caption stay with the FastAPI service (ai-services/).
# Media is handled by the n8n webhook in n8n/n8n.json
AI_DECISION_URL=http://localhost:8000/api/ai/decision
AI_CAPTION_URL=http://localhost:8000/api/ai/caption
AI_MEDIA_URL=http://localhost:5678/webhook

# App
# APP_URL is the URL the AI services container (n8n, ai-services) uses to
# call back to this backend. When the backend runs on the WSL2 host
# machine (not in Docker), set this to the WSL2 host's IP. In a Linux
# host or fully-dockerized setup, use http://host.docker.internal:3000.
APP_URL=http://host.docker.internal:3000
FRONTEND_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
