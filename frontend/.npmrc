# pnpm 11 reads onlyBuiltDependencies from this file (not from
# package.json's "pnpm" field — that's deprecated in pnpm 11).
# Note: in .npmrc the key is kebab-case, not camelCase.
# Each entry is a package name whose native build script is allowed
# to run. Without these, `pnpm dev` (and `pnpm install`) abort with
# "Ignored build scripts: sharp@..., unrs-resolver@...".
only-built-deps[]=sharp
only-built-deps[]=unrs-resolver

