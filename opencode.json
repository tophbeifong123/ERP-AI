{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/build/**",
      ".git/**"
    ]
  },
  "permission": {
    "external_directory": {
      "frontend/**": "deny",
      "**/node_modules/**": "deny"
    }
  },
  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  }
}
