APP_NAME=ERP-AI Services
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Where the NestJS backend lives (used by the media stub to call
# POST /files/presigned/post_media and the image/short_video callbacks).
BACKEND_BASE_URL=http://localhost:3000

# Shared secret: backend sends it as X-Internal-Token; we send it back on callbacks.
# Must match backend's INTERNAL_API_KEY in backend/server/.env
INTERNAL_TOKEN=dev-internal-api-key

GROQ_API_KEY=your-groq-api-key-here
